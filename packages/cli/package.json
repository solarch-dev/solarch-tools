{
  "name": "@solarch/cli",
  "version": "0.8.0",
  "description": "Solarch CLI — architecture drift check, live binding and cloud sync for NestJS codebases",
  "type": "module",
  "license": "SEE LICENSE IN ../../LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/solarch-dev/solarch-tools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://solarch.dev",
  "keywords": [
    "solarch",
    "nestjs",
    "architecture",
    "drift",
    "cli",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "solarch": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate:logo": "node scripts/generate-logo-ascii.mjs",
    "build": "pnpm run generate:logo && tsup src/index.ts src/lib.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@solarch/ast-core": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@ascii-kit/svg": "^0.0.6",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
