{
  "name": "solarch-vscode",
  "displayName": "Solarch",
  "description": "Architecture graph + drift status for Solarch-linked NestJS repos — see the live state of code vs architecture, like Git Graph but for your system design",
  "version": "0.8.4",
  "publisher": "solarch",
  "private": true,
  "icon": "media/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://solarch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/solarch-dev/solarch-tools.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/solarch-dev/solarch-tools/issues"
  },
  "keywords": [
    "solarch",
    "nestjs",
    "architecture",
    "drift",
    "graph",
    "codegen",
    "typescript"
  ],
  "galleryBanner": {
    "color": "#1A1A18",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:solarch.json",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "solarch",
          "title": "Solarch",
          "icon": "media/solarch.svg"
        }
      ]
    },
    "views": {
      "solarch": [
        {
          "id": "solarchState",
          "name": "Architecture",
          "icon": "media/solarch.svg",
          "contextualTitle": "Solarch"
        }
      ]
    },
    "commands": [
      {
        "command": "solarch.refresh",
        "title": "Solarch: Refresh (rescan + re-fetch cloud)",
        "icon": "$(refresh)"
      },
      {
        "command": "solarch.checkDrift",
        "title": "Solarch: Check Drift",
        "icon": "$(git-compare)"
      },
      {
        "command": "solarch.push",
        "title": "Solarch: Push Code Changes to Cloud",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "solarch.pull",
        "title": "Solarch: Pull To-Be Graph",
        "icon": "$(cloud-download)"
      },
      {
        "command": "solarch.login",
        "title": "Solarch: Sign in with API Key",
        "icon": "$(sign-in)"
      },
      {
        "command": "solarch.link",
        "title": "Solarch: Link Project",
        "icon": "$(plug)"
      },
      {
        "command": "solarch.generate",
        "title": "Solarch: Generate Code from Architecture",
        "icon": "$(rocket)"
      },
      {
        "command": "solarch.bind",
        "title": "Solarch: Bind Entity to DTO (live sync)",
        "icon": "$(link)"
      },
      {
        "command": "solarch.selectFolder",
        "title": "Solarch: Select Folder to Track",
        "icon": "$(folder-opened)"
      },
      {
        "command": "solarch.switchProject",
        "title": "Solarch: Switch Project",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "solarch.acknowledge",
        "title": "Solarch: Acknowledge Revision"
      },
      {
        "command": "solarch.openFinding",
        "title": "Solarch: Open Finding"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "solarch.acknowledge",
          "when": "false"
        },
        {
          "command": "solarch.openFinding",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "solarch.switchProject",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "navigation@0"
        },
        {
          "command": "solarch.checkDrift",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "navigation@1"
        },
        {
          "command": "solarch.push",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "navigation@2"
        },
        {
          "command": "solarch.pull",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "navigation@3"
        },
        {
          "command": "solarch.refresh",
          "when": "view == solarchState",
          "group": "navigation@4"
        },
        {
          "command": "solarch.selectFolder",
          "when": "view == solarchState",
          "group": "1_actions@0"
        },
        {
          "command": "solarch.generate",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "1_actions@1"
        },
        {
          "command": "solarch.bind",
          "when": "view == solarchState && solarch.status == 'ok'",
          "group": "1_actions@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "solarchState",
        "contents": "Solarch is starting…\nIf this view stays empty, run the \"Developer: Reload Window\" command — the extension host needs a restart after installing or updating the extension.",
        "when": "!solarch.status"
      },
      {
        "view": "solarchState",
        "contents": "Connect VS Code to your Solarch account to see the live state of this repository's architecture.\n[Sign in with API Key](command:solarch.login)\nGet a key from Solarch → Settings → API Keys.",
        "when": "solarch.status == 'notLoggedIn'"
      },
      {
        "view": "solarchState",
        "contents": "Choose the folder Solarch should track — a project inside this workspace (monorepo subfolders are supported).\n[Select Folder](command:solarch.selectFolder)",
        "when": "solarch.status == 'noFolder'"
      },
      {
        "view": "solarchState",
        "contents": "You're signed in, but this folder isn't linked to a Solarch project yet.\n[Link a Project](command:solarch.link)\nThis writes a solarch.json to the tracked folder (commit it).\n[Change tracked folder](command:solarch.selectFolder)",
        "when": "solarch.status == 'notLinked'"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "node scripts/smoke-scan.mjs",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "dependencies": {
    "@solarch/ast-core": "workspace:*",
    "@solarch/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
