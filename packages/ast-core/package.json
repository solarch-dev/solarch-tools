{
  "name": "@solarch/ast-core",
  "version": "0.1.0",
  "description": "NestJS AST read/write engine — extracts the As-Is architecture graph and performs safe property injection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
