{
  "name": "@solarch/ast-core",
  "version": "0.7.5",
  "description": "NestJS AST read/write engine — extracts the As-Is architecture graph and performs safe property injection",
  "type": "module",
  "license": "SEE LICENSE IN ../../LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/solarch-dev/solarch-tools.git",
    "directory": "packages/ast-core"
  },
  "homepage": "https://solarch.dev",
  "keywords": [
    "solarch",
    "nestjs",
    "architecture",
    "ast",
    "ts-morph"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
